{
  "name": "pasteclean",
  "version": "1.0.0",
  "description": "Zero-backend, ultra-lightweight clipboard cleaner for macOS and Windows",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "tailwind:build": "tailwindcss -i ./renderer/styles.css -o ./renderer/dist.css --minify",
    "tailwind:watch": "tailwindcss -i ./renderer/styles.css -o ./renderer/dist.css --watch",
    "build:icons": "png2icons assets/icon.png assets/icon -allp -bc -i",
    "build:assets": "convert assets/icon.png -resize 16x16 assets/tray-mac.png && convert assets/icon.png -resize 32x32 assets/tray-mac@2x.png && convert assets/icon.png -resize 16x16 assets/tray-win.png && convert assets/icon.png -resize 32x32 assets/tray-win@2x.png",
    "build": "run-s build:icons tailwind:build build:electron",
    "build:mac": "run-s build:icons tailwind:build build:electron:mac",
    "build:win": "run-s build:icons tailwind:build build:electron:win",
    "build:win-store": "run-s build:icons tailwind:build build:electron:appx",
    "build:electron": "node ./node_modules/electron-builder/cli.js",
    "build:electron:mac": "node ./node_modules/electron-builder/cli.js --mac",
    "build:electron:win": "node ./node_modules/electron-builder/cli.js --win",
    "build:electron:appx": "node ./node_modules/electron-builder/cli.js --win appx",
    "postinstall": "node ./node_modules/electron-builder/cli.js install-app-deps"
  },
  "keywords": [
    "clipboard",
    "cleaner",
    "paste",
    "menubar",
    "system-tray"
  ],
  "author": "SurgeGrid",
  "license": "MIT",
  "repository": "https://github.com/PasteKlean/pasteklean.git",
  "homepage": "https://github.com/PasteKlean/pasteklean",
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "npm-run-all": "^4.1.5",
    "png2icons": "^2.0.1",
    "tailwindcss": "^3.4.4"
  },
  "dependencies": {
    "electron-updater": "^6.8.8"
  }
}
