# Windows Store / MSIX
MSIX_PUBLISHER=CN=7DA92BF0-DE5F-4FAF-AE9C-0E3AADBBE3D2
MSIX_IDENTITY_NAME=PasteKlean.PasteKlean
MSIX_APPLICATION_ID=App
MSIX_DISPLAY_NAME=PasteKlean
MSIX_BACKGROUND_COLOR=transparent
MSIX_LANGUAGES=en-US

# Windows code signing for direct-download .exe (EV/OV certificate as .pfx)
WIN_CSC_LINK=path/to/certificate.pfx
WIN_CSC_KEY_PASSWORD=your-pfx-password

# macOS signing and notarization for direct-download .dmg/.zip
CSC_LINK=path/to/DeveloperIDApplication.p12
CSC_KEY_PASSWORD=your-p12-password
CSC_NAME=Developer ID Application: Your Name (TeamID)

# Notarization using App Store Connect API key (recommended)
APPLE_API_KEY=path/to/AuthKey_KEYID.p8
APPLE_API_KEY_ID=KEYID
APPLE_API_ISSUER=ISSUER_ID

# Notarization using Apple ID (alternative)
# APPLE_ID=your-apple-id@example.com
# APPLE_APP_SPECIFIC_PASSWORD=your-app-specific-password
# APPLE_TEAM_ID=TEAMID

# GitHub release publishing and error tracking
GH_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
SENTRY_DSN=https://publicKey@oOrgId.ingest.sentry.io/projectId
