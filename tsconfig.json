{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2022", "DOM"],
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": false,
    "noImplicitAny": false,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "types": ["node", "jest"]
  },
  "include": ["main.js", "preload.js", "renderer/preferences.js", "lib/**/*.js", "test/**/*.js", "types/**/*.d.ts"],
  "exclude": ["node_modules", "dist", "docs", "store-listing"]
}
